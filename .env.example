# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# Datos empresa (para facturas impresas/PDF)
NEXT_PUBLIC_BILLING_COMPANY_NAME=Tu Empresa S.L.
NEXT_PUBLIC_BILLING_COMPANY_NIF=B00000000
NEXT_PUBLIC_BILLING_COMPANY_ADDRESS=Calle Ejemplo 1
NEXT_PUBLIC_BILLING_COMPANY_CP=28001
NEXT_PUBLIC_BILLING_COMPANY_CITY=Madrid
NEXT_PUBLIC_BILLING_COMPANY_PROVINCE=Madrid
NEXT_PUBLIC_BILLING_COMPANY_IBAN=ES00 0000 0000 0000 0000 0000
# Opcional: URL abs. o ruta /... del logotipo en facturas (también en Ajustes → Datos de empresa)
# NEXT_PUBLIC_BILLING_LOGO_URL=/images/logo-web.png

# Serie de facturación (ej: RHB, FAC)
NEXT_PUBLIC_BILLING_SERIE=RHB
